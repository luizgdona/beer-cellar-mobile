{
  "name": "beer-cellar-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.2.3",
    "@expo-google-fonts/playfair-display": "^0.2.3",
    "@react-native-async-storage/async-storage": "~2.1.0",
    "axios": "^1.7.9",
    "expo": "~52.0.0",
    "expo-blur": "~14.0.1",
    "expo-font": "~13.0.1",
    "expo-image-picker": "~16.0.3",
    "expo-linear-gradient": "~14.0.0",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.3",
    "lucide-react-native": "^0.454.0",
    "react": "18.2.0",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.3.0",
    "react-native-svg": "15.8.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/__tests__/setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|lucide-react-native|react-native-svg)"
    ]
  }
}
