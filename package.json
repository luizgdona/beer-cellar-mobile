{
  "name": "beer-cellar-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.2.3",
    "@expo-google-fonts/playfair-display": "^0.2.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "axios": "^1.7.9",
    "expo": "^56.0.0",
    "expo-blur": "~56.0.3",
    "expo-font": "~56.0.5",
    "expo-image-picker": "~56.0.15",
    "expo-linear-gradient": "~56.0.4",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "lucide-react-native": "^0.454.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/src/__tests__/",
      "/__tests__/setup\\.ts$"
    ],
    "setupFiles": [
      "<rootDir>/__tests__/setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|lucide-react-native|react-native-svg)"
    ]
  }
}
